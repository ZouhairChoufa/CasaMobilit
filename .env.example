# .env.example — Copy this file to .env and fill in your values
# CasaMobilité does not require any API keys in V1.
# This file is provided for V2 contributors who may add external services.

# ── Streamlit (optional overrides) ───────────────────────────────
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true

# ── Future: Mapping tile provider API key ────────────────────────
# MAPTILER_API_KEY=your_key_here

# ── Future: Analytics / monitoring ──────────────────────────────
# SENTRY_DSN=your_dsn_here
